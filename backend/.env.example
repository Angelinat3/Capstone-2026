# ============================================================
# Konfigurasi Environment DompetKuy Backend
# Copy file ini, rename jadi .env, lalu sesuaikan nilainya
# ============================================================

# Environment
# Set to 'production' in production to hide stack traces from error responses
NODE_ENV=development

# Server
PORT=3000

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/dompetkuy

# JWT
JWT_SECRET=ganti-dengan-secret-key-yang-kuat
JWT_EXPIRES_IN=7d

# AI Provider Selection
# Options: 'gemini' | 'fastapi' | 'auto'
# - 'gemini': Always use Google Gemini API (requires GEMINI_API_KEY)
# - 'fastapi': Always use external AI Service (endpoint dari tim AI)
# - 'auto': Use Gemini if GEMINI_API_KEY exists, otherwise use FastAPI (default)
AI_PROVIDER=auto

# AI Service (FastAPI OCR lokal di ./paddleocr-onnx-api) - dipakai kalau AI_PROVIDER='fastapi'
# Jalankan dengan:
#   cd paddleocr-onnx-api
#   pip install -r requirements.txt
#   uvicorn api:app --host 0.0.0.0 --port 8000 --reload
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT=30000

# CORS — URL frontend
CORS_ORIGIN=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Google Gemini API (opsional — kalau ada, akan dipakai untuk AI features)
# Dapatkan API key di: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here
