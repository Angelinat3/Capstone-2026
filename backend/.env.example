# ============================================================
# Konfigurasi Environment DompetKuy Backend
# Copy file ini, rename jadi .env, lalu sesuaikan nilainya
# JANGAN commit file .env ke GitHub!
# ============================================================

# Server
PORT=3000

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/dompetkuy

# JWT
JWT_SECRET=ganti-dengan-secret-key-yang-kuat
JWT_EXPIRES_IN=7d

# AI Service (FastAPI dari tim AI)
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT=30000

# CORS — URL frontend
CORS_ORIGIN=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
