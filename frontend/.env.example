# URL Backend (ganti setelah backend siap di Railway/Render)
VITE_API_URL=http://localhost:3000

# Mode dummy: true = pakai data dummy, false = pakai API sungguhan
# (diatur langsung di masing-masing service file: USE_DUMMY = true/false)
